name = "g2ray-codespace-waker"
main = "src/index.js"
compatibility_date = "2026-05-29"

[vars]
# Example: your-codespace-slug
CODESPACE_NAME = "YOUR_CODESPACE_NAME"

# Optional when the panel uses a non-default XRAY_PORT.
# CODESPACE_PORT = "443"

# Optional browser/API retry hint while the XHTTP route is settling.
# ROUTE_POLL_AFTER_SECONDS = "5"

# Optional successful-wake cooldown. Requires WAKER_KV.
# WAKE_COOLDOWN_SECONDS = "60"

# Optional quota-survival Cron gate. Only set true after adding a Cron Trigger.
# QUOTA_SURVIVAL_CRON_ENABLED = "false"

# Optional KV history. Create a KV namespace, then uncomment and set the id.
# [[kv_namespaces]]
# binding = "WAKER_KV"
# id = "YOUR_KV_NAMESPACE_ID"
